@model Tontine.Models.Groupe
@using Tontine.Models

@* Notification de succès *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    var membreActuel = ViewBag.MembreActuel as Membre;

    // --- LOGIQUE MISE À JOUR : LE BOUTON RESTE ACTIF SI LE RETRAIT EST REJETÉ ---
    bool aDejaRetireCeCycle = false;
    if (membreActuel != null)
    {
        // On ne bloque QUE si le statut est "Confirmé" ou "En attente"
        // Si le retrait est "Rejeté", il n'est pas compté dans cette vérification
        aDejaRetireCeCycle = membreActuel.Retraits.Any(r => 
            r.DateDemande >= Model.DateCreation && 
            (r.Statut == "Confirmé" || r.Statut == "En attente"));
    }
}

<div class="container mt-5">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary">@Model.Nom</h1>
            <p class="text-muted">
                👤 Bienvenue <strong>@membreActuel?.Nom</strong> 
                <br>
                <small class="badge bg-light text-dark border">📱 @membreActuel?.Telephone</small>
            </p>
        </div>
        
        <form asp-action="QuitterGroupe" asp-route-groupeId="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger shadow-sm">🚪 Quitter</button>
        </form>
    </div>

    @* --- PROGRESSION --- *@
    @{
        var dateDebut = Model.DateCreation; 
        var dateAujourdhui = DateTime.Now;
        var dureeTotaleMois = Model.NombreMembresPrevu;
        var moisEcoules = ((dateAujourdhui.Year - dateDebut.Year) * 12) + dateAujourdhui.Month - dateDebut.Month;

        if (moisEcoules < 0) moisEcoules = 0;
        var moisAffichage = moisEcoules > dureeTotaleMois ? dureeTotaleMois : moisEcoules;
        double pourcentageTemps = ((double)moisAffichage / dureeTotaleMois) * 100;

        string couleurBarre = "bg-primary";
        if (pourcentageTemps >= 100) couleurBarre = "bg-success";
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-calendar-range text-primary me-2"></i>
                    Progression de la Tontine (Durée : @dureeTotaleMois mois)
                </h6>
                <span class="badge bg-dark">
                    Mois @moisAffichage / @dureeTotaleMois
                </span>
            </div>

            <div class="progress" style="height: 15px; border-radius: 10px; background-color: #f0f2f5;">
                <div class="progress-bar progress-bar-striped progress-bar-animated @couleurBarre" 
                     role="progressbar" 
                     style="width: @pourcentageTemps.ToString("0")%;" 
                     aria-valuenow="@pourcentageTemps" 
                     aria-valuemin="0" 
                     aria-valuemax="100">
                     @if(pourcentageTemps > 10) { <span>@pourcentageTemps.ToString("0")%</span> }
                </div>
            </div>

            <div class="d-flex justify-content-between mt-2 small text-muted">
                <span>Début : @dateDebut.ToString("MMMM yyyy")</span>
                @if (moisEcoules >= dureeTotaleMois)
                {
                    <span class="text-success fw-bold">Tontine terminée ! ✅</span>
                }
                else
                {
                    <span>Fin prévue : @dateDebut.AddMonths(dureeTotaleMois).ToString("MMMM yyyy")</span>
                }
            </div>
        </div>
    </div>

    @* --- STATISTIQUES (5 COLONNES) --- *@
    <div class="row mb-4 text-center g-2">
        <div class="col-md col-6 mb-2">
            <div class="card bg-primary text-white border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h5 class="card-title opacity-75 small">💰 MONTANT</h5>
                    <h2 class="fw-bold h5 mb-1">@Model.MontantParVersement.ToString("N0").Replace(","," ") Ar</h2>
                    <small class="x-small">/ versement</small>
                </div>
            </div>
        </div>
        <div class="col-md col-6 mb-2">
            <div class="card bg-success text-white border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h5 class="card-title opacity-75 small">👥 MEMBRES</h5>
                    <h2 class="fw-bold h5 mb-1">@Model.Membres.Count / @Model.NombreMembresPrevu</h2>
                    <small class="x-small">Participants</small>
                </div>
            </div>
        </div>
        <div class="col-md col-6 mb-2">
            <div class="card bg-info text-white border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h5 class="card-title opacity-75 small">💵 MON TOTAL</h5>
                    <h2 class="fw-bold h5 mb-1">@membreActuel?.Versements.Where(v => v.Statut == "Confirmé").Sum(v => v.Montant).ToString("N0").Replace(","," ") Ar</h2>
                    <small class="x-small">Validés</small>
                </div>
            </div>
        </div>
        <div class="col-md col-6 mb-2">
            <div class="card bg-warning text-dark border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h5 class="card-title opacity-75 small">📊 MES DÉPÔTS</h5>
                    <h2 class="fw-bold h5 mb-1">@membreActuel?.Versements.Count</h2>
                    <small class="x-small">Envois totaux</small>
                </div>
            </div>
        </div>
        <div class="col-md col-12 mb-2">
            <div class="card bg-danger text-white border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h5 class="card-title opacity-75 small text-uppercase">💸 TOTAL RETIRÉ</h5>
                    <h2 class="fw-bold h5 mb-1">@membreActuel?.Retraits.Where(r => r.Statut == "Confirmé").Sum(r => r.Montant).ToString("N0").Replace(","," ") Ar</h2>
                    <small class="x-small">Fonds perçus</small>
                </div>
            </div>
        </div>
    </div>

    @* --- ACTIONS (MODIFIÉ POUR LE RETRAIT UNIQUE) --- *@
    <div class="card border-0 shadow-sm bg-light mb-4">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <h5 class="fw-bold mb-1">Portefeuille de @membreActuel?.Nom</h5>
                <p class="text-muted mb-0 small">Gérez vos cotisations et vos demandes de fonds.</p>
            </div>
            <div class="d-flex gap-2">
                @if (!aDejaRetireCeCycle)
                {
                    <a asp-controller="Retraits" asp-action="Create" asp-route-membreId="@membreActuel?.Id" class="btn btn-outline-danger px-4 fw-bold shadow-sm">
                        <i class="bi bi-cash-stack me-1"></i> Demander Retrait
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary px-4 fw-bold shadow-sm" disabled>
                        <i class="bi bi-lock-fill me-1"></i> Retrait déjà fait
                    </button>
                }
                
                <a asp-controller="Versements" asp-action="Create" asp-route-membreId="@membreActuel?.Id" class="btn btn-success px-4 fw-bold shadow">
                    <i class="bi bi-plus-circle me-1"></i> Verser Maintenant
                </a>
            </div>
        </div>
    </div>

    @* --- HISTORIQUE DES RETRAITS --- *@
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Retraits en attente</h6>
                </div>
                <div class="card-body p-0">
                    @{ var retraitsAttente = membreActuel?.Retraits.Where(r => r.Statut == "En attente").OrderByDescending(r => r.DateDemande).ToList(); }
                    @if (retraitsAttente?.Any() == true) {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 small">
                                <tbody>
                                    @foreach (var r in retraitsAttente) {
                                        <tr>
                                            <td class="ps-3 fw-bold">@r.Montant.ToString("N0") Ar</td>
                                            <td class="text-muted">@r.DateDemande.ToString("dd/MM/yy HH:mm")</td>
                                            <td class="text-end pe-3"><span class="badge bg-warning text-dark">⏳ Attente</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    } else { <p class="p-3 mb-0 text-muted small">Aucun retrait en cours.</p> }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-secondary text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-check2-circle me-2"></i>Retraits Confirmés</h6>
                </div>
                <div class="card-body p-0">
                    @{ var retraitsConfirmes = membreActuel?.Retraits.Where(r => r.Statut == "Confirmé").OrderByDescending(r => r.DateDemande).ToList(); }
                    @if (retraitsConfirmes?.Any() == true) {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 small">
                                <tbody>
                                    @foreach (var r in retraitsConfirmes) {
                                        <tr>
                                            <td class="ps-3 fw-bold text-danger">@r.Montant.ToString("N0") Ar</td>
                                            <td class="text-muted">@r.DateDemande.ToString("dd/MM/yy")</td>
                                            <td class="text-end pe-3"><i class="bi bi-patch-check-fill text-success"></i></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    } else { <p class="p-3 mb-0 text-muted small">Aucun retrait encaissé.</p> }
                </div>
            </div>
        </div>
    </div>

    @* --- LISTE DES MEMBRES --- *@
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Tous les Membres (@Model.Membres.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Membres.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Nom</th>
                                <th>Téléphone</th>
                                <th class="text-center">Versements</th>
                                <th class="text-end pe-3">Total Validé</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var membre in Model.Membres)
                            {
                                <tr class="@(membre.Id == membreActuel?.Id ? "table-info" : "")">
                                    <td class="ps-3 fw-bold">
                                        @membre.Nom
                                        @if (membre.Id == membreActuel?.Id) { <span class="badge bg-primary ms-1">Moi</span> }
                                    </td>
                                    <td>@membre.Telephone</td>
                                    <td class="text-center">@membre.Versements.Count(v => v.Statut == "Confirmé") ✅</td>
                                    <td class="text-end pe-3 fw-bold text-success">@membre.Versements.Where(v => v.Statut == "Confirmé").Sum(v => v.Montant).ToString("N0").Replace(","," ") Ar</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @* --- SUIVI DES ENVOIS (ATTENTE) --- *@
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-warning text-dark py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-hourglass-split me-2"></i>Suivi de mes envois (Versements)</h5>
        </div>
        <div class="card-body p-0">
            @{ var mesEnvois = membreActuel?.Versements.Where(v => v.Statut == "En attente" || v.Statut == "Rejeté").OrderByDescending(v => v.Date).ToList(); }
            @if (mesEnvois?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr class="text-muted">
                                <th class="ps-3">Montant</th>
                                <th>Date</th>
                                <th class="text-center">Preuve</th>
                                <th class="text-end pe-3">Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in mesEnvois)
                            {
                                <tr class="@(v.Statut == "Rejeté" ? "table-danger" : "")">
                                    <td class="ps-3 fw-bold">@v.Montant.ToString("N0") Ar</td>
                                    <td>@v.Date.ToString("dd/MM/yy HH:mm")</td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(v.PreuveImage)) {
                                            <a href="~/uploads/preuves/@v.PreuveImage" target="_blank" class="btn btn-sm btn-outline-secondary py-0">🖼️ Voir</a>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        @if(v.Statut == "En attente") { <span class="badge bg-warning text-dark">⏳ Attente</span> }
                                        else { <span class="badge bg-danger">❌ Rejeté</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            } else { <p class="p-3 mb-0 text-muted small">Aucun versement en attente.</p> }
        </div>
    </div>

    @* --- VERSEMENTS CONFIRMÉS --- *@
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-check-all me-2"></i>Mes Versements Confirmés</h5>
        </div>
        <div class="card-body p-0">
            @{ var mesConfirmes = membreActuel?.Versements.Where(v => v.Statut == "Confirmé").OrderByDescending(v => v.Date).ToList(); }
            @if (mesConfirmes?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Montant</th>
                                <th>Date</th>
                                <th class="text-end pe-3">Preuve</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in mesConfirmes)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-success">@v.Montant.ToString("N0") Ar</td>
                                    <td>@v.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end pe-3">
                                        @if (!string.IsNullOrEmpty(v.PreuveImage)) {
                                            <a href="~/uploads/preuves/@v.PreuveImage" target="_blank" class="text-info text-decoration-none small">📁 Reçu</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            } else { <p class="p-3 mb-0 text-muted small">Aucun versement confirmé.</p> }
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.7rem; }
</style>