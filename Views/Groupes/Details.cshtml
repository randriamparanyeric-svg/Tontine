@model Tontine.Models.Groupe

@{
    ViewData["Title"] = "Administration - " + Model.Nom;
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="fw-bold text-primary">@Model.Nom</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item text-muted">🔐 Espace Administration</li>
                    <li class="breadcrumb-item active">Tableau de bord</li>
                </ol>
            </nav>
        </div>
        
        <div class="d-flex gap-2">
            <form asp-action="QuitterGroupe" asp-route-groupeId="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning shadow-sm">
                    <i class="bi bi-box-arrow-right me-1"></i> Déconnexion
                </button>
            </form>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger shadow-sm" 
               onclick="return confirm('Attention : Cette action est irréversible !')">
                <i class="bi bi-trash me-1"></i> Supprimer le Groupe
            </a>
        </div>
    </div>

@{
    var dateDebut = Model.DateCreation; 
    var dateAujourdhui = DateTime.Now;
    var dureeTotaleMois = Model.NombreMembresPrevu;
    var moisEcoules = ((dateAujourdhui.Year - dateDebut.Year) * 12) + dateAujourdhui.Month - dateDebut.Month;

    if (moisEcoules < 0) moisEcoules = 0;
    var moisAffichage = moisEcoules > dureeTotaleMois ? dureeTotaleMois : moisEcoules;
    double pourcentageTemps = ((double)moisAffichage / dureeTotaleMois) * 100;

    string couleurBarre = "bg-primary";
    if (pourcentageTemps >= 100) couleurBarre = "bg-success";
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-calendar-range text-primary me-2"></i>
                Progression de la Tontine (Durée : @dureeTotaleMois mois)
            </h6>
            <span class="badge bg-dark">
                Mois @moisAffichage / @dureeTotaleMois
            </span>
        </div>

        <div class="progress" style="height: 15px; border-radius: 10px; background-color: #f0f2f5;">
            <div class="progress-bar progress-bar-striped progress-bar-animated @couleurBarre" 
                 role="progressbar" 
                 style="width: @pourcentageTemps.ToString("0")%;" 
                 aria-valuenow="@pourcentageTemps" 
                 aria-valuemin="0" 
                 aria-valuemax="100">
                 @if(pourcentageTemps > 10) { <span>@pourcentageTemps.ToString("0")%</span> }
            </div>
        </div>

        <div class="d-flex justify-content-between mt-2 small text-muted">
            <span>Début : @dateDebut.ToString("MMMM yyyy")</span>
            @if (moisEcoules >= dureeTotaleMois)
            {
                <span class="text-success fw-bold">Tontine terminée ! ✅</span>
            }
            else
            {
                <span>Fin prévue : @dateDebut.AddMonths(dureeTotaleMois).ToString("MMMM yyyy")</span>
            }
        </div>
    </div>
</div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase opacity-75 small fw-bold">💰 Montant Unitaire</h6>
                    <h3 class="mb-0">@Model.MontantParVersement.ToString("N0").Replace(","," ")<small class="fs-6">Ar</small></h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase opacity-75 small fw-bold">👥 Membres</h6>
                    <h3 class="mb-0">@Model.Membres.Count / @Model.NombreMembresPrevu</h3>
                </div>
            </div>
        </div>
      <div class="col-md-3">
    <div class="card border-0 shadow-sm bg-info text-white h-100">
        <div class="card-body">
            <h6 class="text-uppercase opacity-75 small fw-bold">💵 Fond en Caisse</h6>
            @{
                // On convertit les sommes en double pour être compatible avec SQLite et éviter l'erreur CS0019
                var totalVersements = (double)Model.Versements
                    .Where(v => v.Statut == "Confirmé")
                    .Sum(v => v.Montant);
                
                var totalRetraits = (double)Model.Membres
                    .SelectMany(m => m.Retraits)
                    .Where(r => r.Statut == "Confirmé")
                    .Sum(r => r.Montant);
                
                // Maintenant, les deux sont des 'double', la soustraction fonctionne
                var soldeCaisse = totalVersements - totalRetraits;
            }
            <h3 class="mb-0">@soldeCaisse.ToString("N0").Replace(","," ")<small class="fs-6">Ar</small></h3>
            <small class="opacity-75">Net (Versements - Retraits)</small>
        </div>
    </div>
</div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase opacity-75 small fw-bold">⏳ En Attente</h6>
                    <h3 class="mb-0">@Model.Versements.Where(v => v.Statut == "En attente").Sum(v => v.Montant).ToString("N0").Replace(","," ")<small class="fs-6">Ar</small></h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body bg-light rounded">
            <h5 class="card-title fw-bold"><i class="bi bi-share me-2 text-primary"></i>Lien d'invitation</h5>
            <p class="text-muted small">Partagez ce lien pour que les membres puissent rejoindre le groupe et effectuer leurs versements.</p>
            <div class="input-group">
                <input type="text" class="form-control bg-white border-primary" readonly id="shareLink" 
                       value="@($"{Context.Request.Scheme}://{Context.Request.Host}/groupe/{Model.CodePartage}")">
                <button class="btn btn-primary" onclick="copyLink()">
                    <i class="bi bi-clipboard me-1"></i> Copier
                </button>
            </div>
        </div>
    </div>

    @* --- SECTION VERSEMENTS À VALIDER --- *@
    <div class="card border-0 shadow-sm mb-4 border-start border-warning border-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark">
                <i class="bi bi-clock-history me-2 text-warning"></i>Versements à valider
            </h5>
            <span class="badge bg-warning text-dark rounded-pill">
                @Model.Versements.Count(v => v.Statut == "En attente") en attente
            </span>
        </div>
        <div class="card-body">
            @{ var pending = Model.Versements.Where(v => v.Statut == "En attente").ToList(); }
            @if (pending.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Membre</th>
                                <th>Montant</th>
                                <th>Mode</th>
                                <th>Preuve</th>
                                <th>Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in pending.OrderByDescending(v => v.Date))
                            {
                                <tr>
                                    <td><strong>@v.Membre?.Nom</strong></td>
                                    <td class="fw-bold text-success">@v.Montant.ToString("N0").Replace(","," ") Ar</td>
                                    <td><span class="badge bg-light text-dark border">@v.ModePaiement</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(v.PreuveImage))
                                        {
                                            <a href="~/uploads/preuves/@v.PreuveImage" target="_blank" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-eye"></i> Voir Reçu
                                            </a>
                                        }
                                        else { <span class="text-muted small italic">Aucun fichier</span> }
                                    </td>
                                    <td class="small text-muted">@v.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <div class="btn-group shadow-sm">
                                            <form asp-action="Confirmer" asp-controller="Versements" asp-route-id="@v.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success rounded-start">Valider</button>
                                            </form>
                                            <form asp-action="Rejeter" asp-controller="Versements" asp-route-id="@v.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger rounded-end" onclick="return confirm('Rejeter ce paiement ?')">Refuser</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-check2-all fs-1 text-muted"></i>
                    <p class="text-muted mt-2">Tous les versements sont à jour !</p>
                </div>
            }
        </div>
    </div>

    @* --- NOUVELLE SECTION : RETRAITS À VALIDER --- *@
    <div class="card border-0 shadow-sm mb-4 border-start border-danger border-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark">
                <i class="bi bi-cash-stack me-2 text-danger"></i>Demandes de retraits
            </h5>
            <span class="badge bg-danger rounded-pill">
                @{
                    var retraitsAttente = Model.Membres.SelectMany(m => m.Retraits).Where(r => r.Statut == "En attente").ToList();
                }
                @retraitsAttente.Count en attente
            </span>
        </div>
        <div class="card-body">
            @if (retraitsAttente.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Membre</th>
                                <th>Montant demandé</th>
                                <th>Date Demande</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in retraitsAttente.OrderByDescending(x => x.DateDemande))
                            {
                                <tr>
                                    <td><strong>@r.Membre?.Nom</strong><br><small class="text-muted">@r.Membre?.Telephone</small></td>
                                    <td class="fw-bold text-danger">@r.Montant.ToString("N0").Replace(",", " ") Ar</td>
                                    <td class="small text-muted">@r.DateDemande.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <div class="btn-group shadow-sm">
                                            <form asp-action="Confirmer" asp-controller="Retraits" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success rounded-start" 
                                                        onclick="return confirm('Confirmer que vous avez payé ce montant à @r.Membre?.Nom ?')">
                                                    Valider paiement
                                                </button>
                                            </form>
                                            <form asp-action="Rejeter" asp-controller="Retraits" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-end">Refuser</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-info-circle fs-1 text-muted"></i>
                    <p class="text-muted mt-2">Aucune demande de retrait en attente.</p>
                </div>
            }
        </div>
    </div>

    @* --- LISTE DES MEMBRES --- *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
            <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-people me-2"></i>Membres du groupe</h5>
            <a asp-controller="Membres" asp-action="Create" asp-route-groupeId="@Model.Id" class="btn btn-sm btn-primary">
                <i class="bi bi-person-plus me-1"></i> Ajouter un membre
            </a>
        </div>
        <div class="card-body">
            @if (Model.Membres.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Téléphone</th>
                                <th class="text-center">Versements</th>
                                <th>Total Cotisé</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var membre in Model.Membres)
                            {
                                <tr>
                                    <td class="fw-bold">@membre.Nom</td>
                                    <td>@membre.Telephone</td>
                                    <td class="text-center"><span class="badge bg-secondary rounded-pill">@membre.Versements.Count</span></td>
                                    <td class="fw-bold">@membre.Versements.Where(v => v.Statut == "Confirmé").Sum(v => v.Montant).ToString("N0").Replace(","," ") Ar</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-1">
                                            <a asp-controller="Membres" asp-action="Edit" asp-route-id="@membre.Id" class="btn btn-sm btn-outline-secondary" title="Éditer">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-controller="Membres" asp-action="Delete" asp-route-id="@membre.Id" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center text-muted">Aucun membre pour le moment.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyLink() {
            const copyText = document.getElementById("shareLink");
            copyText.select();
            copyText.setSelectionRange(0, 99999);

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(copyText.value).then(() => {
                    afficherAlerte();
                }).catch(err => {
                    executerCopieClassique();
                });
            } else {
                executerCopieClassique();
            }
        }

        function executerCopieClassique() {
            try {
                document.execCommand("copy");
                afficherAlerte();
            } catch (err) {
                console.error("Impossible de copier", err);
            }
        }

        function afficherAlerte() {
            alert("✅ Lien d'invitation copié avec succès !");
        }
    </script>
}