@model Tontine.Models.Groupe

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="mb-4 text-center">📋 Créer une nouvelle Tontine</h1>

            <form asp-action="Create" method="post" class="card p-4 shadow-sm">
                @Html.AntiForgeryToken()

                <h5 class="text-primary border-bottom pb-2 mb-3">🏠 Informations du Groupe</h5>
                
                <div class="form-group mb-3">
                    <label asp-for="Nom" class="form-label fw-bold">Nom de la Tontine</label>
                    <input asp-for="Nom" class="form-control" placeholder="Ex: Tontine Famille">
                    <span asp-validation-for="Nom" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description (optionnel)</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Décrivez l'objectif du groupe..."></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
    <label asp-for="MontantParVersement" class="form-label fw-bold">💰 Montant / Versement (Ar)</label>
    
    <input type="text" id="MontantVisuel" class="form-control" placeholder="Ex: 50 000">
    
    <input type="hidden" asp-for="MontantParVersement" id="MontantReel">
    
    <span asp-validation-for="MontantParVersement" class="text-danger"></span>
</div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="NombreMembresPrevu" class="form-label fw-bold">👥 Nombre de Membres</label>
                            <input asp-for="NombreMembresPrevu" type="number" class="form-control" placeholder="Ex:10">
                            <span asp-validation-for="NombreMembresPrevu" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <h5 class="text-primary border-bottom pb-2 mt-4 mb-3">🔑 Accès Administrateur (Trésorier)</h5>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="NomAdmin" class="form-label fw-bold">Votre Nom complet</label>
                            <input asp-for="NomAdmin" class="form-control" placeholder="Nom et Prénom">
                            <span asp-validation-for="NomAdmin" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TelephoneAdmin" class="form-label fw-bold">Téléphone</label>
                            <input asp-for="TelephoneAdmin" class="form-control" placeholder="+261...">
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="AdminEmail" class="form-label fw-bold">📧 Votre Adresse Email</label>
                    <input asp-for="AdminEmail" class="form-control" placeholder="votre@email.com">
                    <small class="text-muted italic">Sert d'identifiant et pour la validation par le développeur.</small>
                    <span asp-validation-for="AdminEmail" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="MotDePasseHash" class="form-label fw-bold">🔐 Mot de Passe de Gestion</label>
                    <input asp-for="MotDePasseHash" type="password" class="form-control" placeholder="Choisissez un mot de passe fort">
                    <small class="text-danger">⚠️ Ne partagez pas ce mot de passe, il protège vos accès trésorier.</small>
                    <span asp-validation-for="MotDePasseHash" class="text-danger"></span>
                </div>

                <div class="alert alert-warning mb-4">
                    <i class="bi bi-info-circle-fill"></i> Une fois créée, votre tontine sera mise en <strong>attente de validation</strong> par le développeur technique.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success btn-lg px-4 shadow">✅ Lancer la demande</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
<script>
    const inputVisuel = document.getElementById('MontantVisuel');
    const inputReel = document.getElementById('MontantReel');

    inputVisuel.addEventListener('input', function (e) {
        // 1. On récupère la valeur saisie en ne gardant que les chiffres
        let valeur = e.target.value.replace(/\D/g, '');

        // 2. On met à jour le champ caché (celui qui sera envoyé au serveur)
        inputReel.value = valeur;

        // 3. On reformate l'affichage pour l'utilisateur avec des espaces
        if (valeur !== "") {
            // Formate le nombre avec des espaces (ex: 1 000 000)
            e.target.value = new Intl.NumberFormat('fr-FR').format(valeur);
        } else {
            e.target.value = "";
        }
    });

    // Optionnel : Au chargement de la page, si le champ a déjà une valeur (ex: en édition)
    window.addEventListener('DOMContentLoaded', (event) => {
        if (inputReel.value) {
            inputVisuel.value = new Intl.NumberFormat('fr-FR').format(inputReel.value);
        }
    });
</script>