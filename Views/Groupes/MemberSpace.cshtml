@model Tontine.Models.Groupe
@{
    var membre = ViewBag.Membre as Tontine.Models.Membre;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>@Model.Nom</h1>
            <p class="text-muted">Espace membre — @membre?.Nom</p>
        </div>
        <a asp-action="VoirCommeMembe" asp-route-codePartage="@Model.CodePartage" class="btn btn-secondary">🔙 Changer de membre</a>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5>👤 Vous :</h5>
                    <p><strong>Nom :</strong> @membre?.Nom</p>
                    <p><strong>Téléphone :</strong> @membre?.Telephone</p>
                    <p><strong>Solde :</strong> @membre?.Solde.ToString("N0") Ar</p>
                </div>
            </div>

            <div class="mt-3">
                <a asp-controller="Versements" asp-action="Create" asp-route-membreId="@membre?.Id" class="btn btn-lg btn-success">➕ Verser Maintenant</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <h6>Membres (@Model.Membres.Count)</h6>
                    <ul class="list-unstyled">
                        @foreach (var m in Model.Membres)
                        {
                            <li>@m.Nom (@m.Telephone)</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Historique rapide -->
    <div class="card">
        <div class="card-header bg-info text-white">Historique des versements confirmés</div>
        <div class="card-body">
            @if (Model.Versements.Where(v => v.Statut == "Confirmé").Any())
            {
                <table class="table">
                    <thead>
                        <tr><th>Date</th><th>Montant</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Versements.Where(v => v.Statut == "Confirmé" && v.MembreId == membre.Id).OrderByDescending(v => v.Date))
                        {
                            <tr>
                                <td>@v.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@v.Montant.ToString("N0") Ar</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Aucun versement confirmé pour le moment.</p>
            }
        </div>
    </div>
</div>