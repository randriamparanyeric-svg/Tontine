@model Tontine.Models.Groupe

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>@Model.Nom</h1>
            <p class="text-muted">🔐 Espace Admin</p>
        </div>
        <div class="d-flex gap-2">
            <form asp-action="QuitterGroupe" asp-route-groupeId="@Model.Id" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">🚪 Déconnexion</button>
            </form>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                🗑️ Supprimer
            </a>
        </div>
    </div>

    <!-- ALERTE DANGER SI PEU DE MEMBRES -->
    @if (Model.Membres.Count == 0)
    {
        <div class="alert alert-warning mb-4">
            <strong>⚠️ Attention :</strong> Vous n'avez aucun membre inscrit. <a asp-controller="Membres" asp-action="Create" asp-route-groupeId="@Model.Id">Ajouter un membre</a>
        </div>
    }

    <!-- REST DU CONTENU (statistiques, versements, membres...) -->
    <!-- ... reste du fichier ... -->