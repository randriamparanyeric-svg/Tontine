@model string

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            @* --- ALERTES --- *@
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <div asp-validation-summary="All" class="small"></div>
                </div>
            }

            @* --- CARTE --- *@
            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">🔑 Mot de passe oublié</h3>
                    <p class="text-muted small">
                        Entrez l'adresse email associée à votre tontine. 
                        Nous vous enverrons un lien pour réinitialiser votre accès.
                    </p>
                    
                    <form asp-action="ForgotPassword" method="post">
                        <div class="form-group mb-3">
                            <label class="form-label">Votre Email Admin</label>
                            <input type="email" name="email" class="form-control" placeholder="exemple@mail.com" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mb-3">Envoyer le lien de récupération</button>
                    </form>
                    
                    <div class="text-center">
                        <a asp-action="AccederMembre" class="text-decoration-none small text-secondary">Retour à la connexion</a>
                    </div>
                </div>
                
                @* --- CONTACT SUPPORT (M-Vola & WhatsApp) --- *@
                <div class="card-footer bg-light border-0 py-3 text-center">
                    <small class="text-muted d-block mb-1">Besoin d'aide ?</small>
                    <strong class="small"><i class="bi bi-whatsapp"></i> +261 32 64 572 08</strong><br/>
                    <strong class="small"><i class="bi bi-phone-fill"></i> +261 34 64 474 61</strong><br/>  
                </div>
            </div>
        </div>
    </div>
</div>