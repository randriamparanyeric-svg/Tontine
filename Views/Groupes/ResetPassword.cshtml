@model Tontine.Models.Groupe

@{
    ViewData["Title"] = "Réinitialiser le mot de passe";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center p-4">
                    <h4 class="mb-0">🛡️ Nouveau mot de passe</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small text-center">
                        Choisissez un nouveau mot de passe sécurisé pour l'administration de votre tontine.
                    </p>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger small">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" name="token" value="@Context.Request.Query["token"]" />

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Nouveau mot de passe</label>
                            <input type="password" name="nouveauMdp" id="nouveauMdp" class="form-control form-control-lg" 
                                   placeholder="Minimum 6 caractères" required minlength="6" autofocus>
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">Confirmer le mot de passe</label>
                            <input type="password" id="confirmMdp" class="form-control form-control-lg" 
                                   placeholder="Répétez le mot de passe" required>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">
                            💾 Enregistrer le nouveau mot de passe
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="text-center mt-3">
                <a asp-action="AccederMembre" asp-route-codePartage="@Context.Request.Query["codePartage"]" class="text-decoration-none text-muted small">
                    Retour à la page de connexion
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Vérification côté client pour s'assurer que les deux champs sont identiques
        const form = document.querySelector('form');
        const mdp = document.getElementById('nouveauMdp');
        const confirmMdp = document.getElementById('confirmMdp');

        form.addEventListener('submit', function(e) {
            if (mdp.value !== confirmMdp.value) {
                e.preventDefault();
                alert("Erreur : Les deux mots de passe ne sont pas identiques !");
            }
        });
    </script>
}