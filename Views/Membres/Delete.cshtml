@model Tontine.Models.Membre

@{
    ViewData["Title"] = "Supprimer membre";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirmation de suppression</h5>
                </div>
                <div class="card-body p-4">
                    <p class="lead">Êtes-vous sûr de vouloir supprimer le membre suivant ?</p>
                    
                    <div class="bg-light p-3 rounded mb-4">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted small text-uppercase">Nom</dt>
                            <dd class="col-sm-8 fw-bold">@Model.Nom</dd>

                            <dt class="col-sm-4 text-muted small text-uppercase">Téléphone</dt>
                            <dd class="col-sm-8">@Model.Telephone</dd>

                            <dt class="col-sm-4 text-muted small text-uppercase">Groupe</dt>
                            <dd class="col-sm-8">@Model.Groupe?.Nom</dd>
                        </dl>
                    </div>

                    <div class="alert alert-warning border-0 small">
                        <i class="bi bi-info-circle me-1"></i> 
                        Toutes les données associées (versements, photos CIN) seront définitivement supprimées.
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
    @* Bouton Annuler redirige vers le groupe *@
    <a asp-controller="Groupes" asp-action="Details" asp-route-id="@Model.GroupeId" class="btn btn-light border">
        Annuler
    </a>
    
    <button type="submit" class="btn btn-danger px-4">
        <i class="bi bi-trash me-1"></i> Supprimer définitivement
    </button>
</div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>