@model Tontine.Models.Membre

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>@Model.Nom</h1>
            <p class="text-muted">Membre depuis @Model.DateAdhesion.ToString("dd/MM/yyyy")</p>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">✏️ Éditer</a>
        </div>
    </div>

    <!-- INFO MEMBRE -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">📋 Informations Personnelles</h5>
                    <p><strong>📱 Téléphone:</strong> @Model.Telephone</p>
                    <p><strong>📧 Email:</strong> @(Model.Email ?? "Non renseigné")</p>
                    <p><strong>👥 Groupe:</strong> @Model.Groupe?.Nom</p>
                    <p><strong>📅 Date d'adhésion:</strong> @Model.DateAdhesion.ToString("dd/MM/yyyy")</p>
                    <p><strong>Statut:</strong> 
                        @if (Model.Actif)
                        {
                            <span class="badge bg-success">Actif</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactif</span>
                        }
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">💰 Solde</h5>
                    <h2 class="text-success">@Model.Solde.ToString("N0") Ar</h2>
                    <p class="text-muted">Versements totaux</p>
                </div>
            </div>
        </div>
    </div>

    <!-- STATISTIQUES -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">💵 Solde</h5>
                    <h2>@Model.Solde.ToString("N0")</h2>
                    <small>Ar</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">📊 Versements</h5>
                    <h2>@Model.Versements.Count</h2>
                    <small>au total</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">📅 Dernier Versement</h5>
                    <h5>
                        @if (Model.Versements.Any())
                        {
                            @Model.Versements.OrderByDescending(v => v.Date).First().Date.ToString("dd/MM/yyyy")
                        }
                        else
                        {
                            <span>Aucun</span>
                        }
                    </h5>
                </div>
            </div>
        </div>
    </div>

    <!-- VERSEMENTS -->
    <div class="card">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">💵 Historique des Versements (@Model.Versements.Count)</h5>
        
        </div>
        <div class="card-body">
            @if (Model.Versements.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Montant</th>
                                <th>Date</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var versement in Model.Versements.OrderByDescending(v => v.Date))
                            {
                                <tr>
                                    <td><strong>@versement.Montant.ToString("N0")</strong> Ar</td>
                                    <td>@versement.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-success">@versement.Statut</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Aucun versement pour le moment. <a asp-controller="Versements" asp-action="Create" asp-route-membreId="@Model.Id">Ajouter un versement</a>
                </div>
            }
        </div>
    </div>
</div>