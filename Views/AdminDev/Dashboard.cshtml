@model IEnumerable<Tontine.Models.Groupe>

@{
    ViewData["Title"] = "Console Développeur";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3">
        <h2 class="mb-0">🛠 Gestionnaire Développeur</h2>
        <div class="d-flex gap-2">
            <span class="badge bg-info text-dark d-flex align-items-center">Total : @Model.Count() tontines</span>
            <a asp-action="Logout" class="btn btn-outline-danger btn-sm">Déconnexion</a>
        </div>
    </div>

    @* Affichage des alertes (Succès ou Erreur de mot de passe) *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive mt-4">
        <table class="table table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Nom de la Tontine</th>
                    <th>Administrateur</th>
                    <th class="text-center">Durée Prévue</th>
                    <th>Progression (Temps)</th>
                    <th class="text-center">Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // --- CALCUL DE LA PROGRESSION TEMPORELLE ---
                    var dateDebut = item.DateCreation;
                    var dateActuelle = DateTime.Now;
                    var dureeTotaleMois = item.NombreMembresPrevu;

                    var moisEcoules = ((dateActuelle.Year - dateDebut.Year) * 12) + dateActuelle.Month - dateDebut.Month;
                    if (moisEcoules < 0) moisEcoules = 0;
                    
                    var moisAffichage = moisEcoules > dureeTotaleMois ? dureeTotaleMois : moisEcoules;
                    double pourcentage = ((double)moisAffichage / dureeTotaleMois) * 100;
                    // -------------------------------------------

                    <tr>
                        <td>@item.DateCreation.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="fw-bold text-primary">@item.Nom</span>
                        </td>
                        <td>
                            <div>@item.NomAdmin</div>
                            <small class="text-muted d-block">@item.AdminEmail</small>
                            @* AJOUT DU NUMÉRO DE TÉLÉPHONE *@
                            <small class="text-success fw-bold"><i class="bi bi-telephone"></i> @item.TelephoneAdmin</small>
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill bg-secondary">@item.NombreMembresPrevu mois</span>
                        </td>
                        <td style="min-width: 150px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height: 8px;">
                                    <div class="progress-bar @(pourcentage >= 100 ? "bg-success" : "bg-info")" 
                                         role="progressbar" 
                                         style="width: @pourcentage.ToString("0")%"></div>
                                </div>
                                <small class="fw-bold">@moisAffichage/@dureeTotaleMois</small>
                            </div>
                            @if(moisEcoules >= dureeTotaleMois) {
                                <small class="text-success" style="font-size: 0.7rem;">Terminé ✅</small>
                            } else {
                                <small class="text-muted" style="font-size: 0.7rem;">En cours...</small>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.EstValideParDev)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Activée
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-clock"></i> En attente
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <form asp-action="ToggleValidation" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    @if (!item.EstValideParDev)
                                    {
                                        <button type="submit" class="btn btn-sm btn-success px-3">Valider</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" 
                                                onclick="return confirm('Voulez-vous vraiment suspendre l\'accès ?')">
                                            Suspendre
                                        </button>
                                    }
                                </form>

                                <button type="button" class="btn btn-sm btn-danger" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#deleteModal" 
                                        data-groupeid="@item.Id" 
                                        data-groupenom="@item.Nom">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            Aucune tontine enregistrée pour le moment.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Modal de suppression *@
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">🛡️ Validation de sécurité</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="DeleteGroupe" asp-controller="AdminDev" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p>Vous êtes sur le point de supprimer la tontine : <strong id="nomGroupeAffichage"></strong></p>
                    <p class="text-danger fw-bold small"><i class="bi bi-exclamation-triangle"></i> Cette action est irréversible et supprimera toutes les données liées.</p>
                    
                    <input type="hidden" name="id" id="groupeIdASupprimer" />
                    
                    <div class="mb-3 mt-3">
                        <label class="form-label fw-bold">Mot de passe développeur requis :</label>
                        <input type="password" name="passwordConfirm" class="form-control border-danger" required placeholder="Saisissez votre mot de passe">
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger px-4">Confirmer la suppression</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-groupeid');
            var nom = button.getAttribute('data-groupenom');

            document.getElementById('groupeIdASupprimer').value = id;
            document.getElementById('nomGroupeAffichage').textContent = nom;
        });
    </script>
}