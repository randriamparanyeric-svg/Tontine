@model IEnumerable<Tontine.Models.Versement>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>💵 Historique des Versements</h1>
        <a asp-action="Index" asp-controller="Groupes" class="btn btn-outline-secondary">🏠 Retour aux Groupes</a>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Membre</th>
                                <th>Groupe</th>
                                <th>Montant</th>
                                <th>Mode</th>
                                <th>Preuve</th>
                                <th>Date</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var versement in Model.OrderByDescending(v => v.Date))
                            {
                                <tr>
                                    <td><strong>@versement.Membre?.Nom</strong></td>
                                    <td><span class="badge bg-light text-dark">@versement.Groupe?.Nom</span></td>
                                    <td><span class="fw-bold">@versement.Montant.ToString("N0")</span> Ar</td>
                                    <td>
                                        <small class="text-muted">@versement.ModePaiement</small>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(versement.PreuveImage))
                                        {
                                            <i class="bi bi-image text-primary" 
                                               style="cursor: pointer; font-size: 1.2rem;" 
                                               data-bs-toggle="modal" 
                                               data-bs-target="#modalImg@versement.Id"></i>

                                            <div class="modal fade" id="modalImg@versement.Id" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content">
                                                        <div class="modal-body p-0 text-center">
                                                            <img src="~/uploads/preuves/@versement.PreuveImage" class="img-fluid rounded" />
                                                        </div>
                                                        <div class="modal-footer border-0">
                                                            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Fermer</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td><small>@versement.Date.ToString("dd/MM/yyyy HH:mm")</small></td>
                                    <td>
                                        @if (versement.Statut == "Confirmé")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">
                                                <i class="bi bi-check-circle-fill"></i> @versement.Statut
                                            </span>
                                        }
                                        else if (versement.Statut == "En attente")
                                        {
                                            <span class="badge bg-warning-subtle text-warning-dark border border-warning-subtle">
                                                <i class="bi bi-clock-fill"></i> @versement.Statut
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                                <i class="bi bi-x-circle-fill"></i> @versement.Statut
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cash-stack display-1 text-muted opacity-25"></i>
            <p class="mt-3 text-muted">Aucun versement enregistré pour le moment.</p>
        </div>
    }
</div>

<style>
    .text-warning-dark { color: #856404; }
    .bg-success-subtle { background-color: #d1e7dd; }
    .bg-warning-subtle { background-color: #fff3cd; }
    .bg-danger-subtle { background-color: #f8d7da; }
</style>