@model Tontine.Models.Versement
@using Tontine.Models

@{
    var membreActuel = ViewBag.MembreActuel as Membre;
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>💵 Nouveau Versement</h1>
        <a asp-action="VoirCommeMembe" asp-controller="Groupes" asp-route-codePartage="@Model.Membre?.Groupe?.CodePartage" class="btn btn-outline-secondary">🔙 Retour</a>
    </div>

    @* CRUCIAL : enctype="multipart/form-data" pour permettre l'envoi de l'image preuve *@
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="card shadow-sm border-0 p-4">
        @Html.AntiForgeryToken()

        <div class="alert alert-info border-0 shadow-sm mb-4">
            <div class="row">
                <div class="col-md-4"><strong>👤 Membre:</strong> @Model.Membre?.Nom</div>
                <div class="col-md-4"><strong>👥 Groupe:</strong> @Model.Membre?.Groupe?.Nom</div>
                <div class="col-md-4"><strong>💰 Montant prévu:</strong> @Model.Membre?.Groupe?.MontantParVersement.ToString("N0").Replace(",", " ") Ar</div>
            </div>
        </div>

        <input type="hidden" asp-for="MembreId" />
        <input type="hidden" asp-for="GroupeId" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Montant" class="form-label fw-bold">💰 Montant du versement (Ar)</label>
                
                @* Champ visuel pour la saisie avec espaces *@
                <input type="text" id="MontantVisuel" class="form-control form-control-lg border-primary" placeholder="Entrez le montant">
                
                @* Champ réel caché pour le serveur (chiffre pur) *@
                <input type="hidden" asp-for="Montant" id="MontantReel" 
                       value="@(Model.Montant > 0 ? Model.Montant : (Model.Membre?.Groupe?.MontantParVersement ?? 0))">
                
                <span asp-validation-for="Montant" class="text-danger"></span>
                <small class="text-muted">Recommandé : @Model.Membre?.Groupe?.MontantParVersement.ToString("N0").Replace(",", " ") Ar</small>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Date" class="form-label fw-bold">📅 Date de transaction</label>
                <input asp-for="Date" type="datetime-local" class="form-control form-control-lg">
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
        </div>

        <hr class="my-4">

        <div class="mb-4">
            <label class="form-label fw-bold">💳 Choisissez votre mode de paiement</label>
            <select name="ModePaiement" id="selectMode" class="form-select form-select-lg border-primary" required>
                <option value="">-- Sélectionner --</option>
                <option value="Mvola">Mvola</option>
                <option value="Orange Money">Orange Money</option>
                <option value="Airtel Money">Airtel Money</option>
                <option value="Espèce">En Espèce (Main à main)</option>
            </select>
        </div>

        <div class="mb-4 p-4 border rounded bg-light shadow-sm" id="sectionPreuve" style="display: none;">
            <label class="form-label fw-bold text-danger"><i class="bi bi-camera-fill"></i> Capture d'écran de la preuve</label>
            <input type="file" name="fichierPreuve" id="inputPreuve" class="form-control" accept="image/*">
            <div class="form-text mt-2 text-dark">
                ⚠️ <strong>Obligatoire</strong> : Veuillez joindre le reçu de votre transfert mobile.
            </div>
        </div>

        <div class="alert alert-warning border-0 d-flex align-items-center mb-4">
            <i class="bi bi-info-circle-fill me-2 fs-4"></i>
            <div>Votre versement sera examiné par l'administrateur avant d'être ajouté à votre solde.</div>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
            <button type="submit" class="btn btn-success btn-lg px-5 shadow">🚀 Envoyer le Versement</button>
            <a asp-action="VoirCommeMembe" asp-controller="Groupes" asp-route-codePartage="@Model.Membre?.Groupe?.CodePartage" class="btn btn-light btn-lg px-5 border">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

  <script>
    document.addEventListener("DOMContentLoaded", function() {
        const inputVisuel = document.getElementById('MontantVisuel');
        const inputReel = document.getElementById('MontantReel');

        // FONCTION DE FORMATAGE CORRIGÉE
        function rafraichirAffichage(valeurBrute) {
            if (!valeurBrute) return "";

            // 1. On transforme en texte et on enlève tout ce qui est après la virgule ou le point
            // Cela transforme "10000,0" ou "10000.0" en "10000"
            let chaine = valeurBrute.toString().split(',')[0].split('.')[0];

            // 2. On ne garde que les chiffres au cas où
            let propre = chaine.replace(/\D/g, '');

            if (propre === "") return "";

            // 3. On affiche avec les espaces
            return new Intl.NumberFormat('fr-FR').format(propre);
        }

        // INITIALISATION
        if (inputReel && inputReel.value) {
            // On nettoie la valeur réelle pour être sûr qu'elle ne contient pas de décimales pour C#
            let valeurNettoyee = inputReel.value.toString().split(',')[0].split('.')[0].replace(/\D/g, '');
            inputReel.value = valeurNettoyee; 
            
            inputVisuel.value = rafraichirAffichage(valeurNettoyee);
        }

        // SAISIE
        inputVisuel.addEventListener('input', function (e) {
            let brute = e.target.value.replace(/\D/g, '');
            inputReel.value = brute; 
            e.target.value = rafraichirAffichage(brute);
        });

        // --- Garder votre code pour le mode de paiement ici ---
        const selectMode = document.getElementById('selectMode');
        const sectionPreuve = document.getElementById('sectionPreuve');
        const inputPreuve = document.getElementById('inputPreuve');
        if(selectMode) {
            selectMode.addEventListener('change', function () {
                const modesDigitaux = ['Mvola', 'Orange Money', 'Airtel Money'];
                if (modesDigitaux.includes(this.value)) {
                    sectionPreuve.style.display = 'block';
                    inputPreuve.setAttribute('required', 'required');
                } else {
                    sectionPreuve.style.display = 'none';
                    inputPreuve.removeAttribute('required');
                    inputPreuve.value = ""; 
                }
            });
        }
    });
</script>
}